# vi: ft=bash
# Export variables
export EDITOR='nvim'

# Vim aliases
alias vi='nvim'
alias vim='nvim'
alias gvim='neovide'

# Aliases
alias grep='grep --color'
alias egrep='egrep --color=auto'
alias fgrep='fgrep --color=auto'

# Emulates Apple's open
alias open='start'

# Directory listings
alias ls='ls -1 -hF --color=auto'
alias la='ls -lA'
