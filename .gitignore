.DS_Store
git-sdk-64/

# Ignore local WezTerm config files
wezterm/local_launch.lua

# Machine-specific ZSH files
.zcompdump
.antidote
.zsh_history
.zsh_plugins.zsh
.zcompcache
.zsh_history.*

# Generated completion files (auto-managed by completion-specs loader)
zsh/completions/*
!zsh/completions/.gitkeep

# Machine-specific completion specs
zsh/completion-specs-local/
