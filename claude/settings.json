{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git switch *)",
      "Bash(git checkout -- *)",
      "Bash(git branch)",
      "Bash(git branch -c *)",
      "Bash(git stash push *)",
      "Bash(git stash pop *)",
      "Bash(git stash list)",
      "Bash(git stash show *)",
      "Bash(git remote *)",
      "Bash(git show *)",
      "Bash(git tag *)",
      "Bash(uv run *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(cargo build *)",
      "Bash(cargo test *)",
      "Bash(cargo clippy *)",
      "Bash(cargo fmt *)",
      "Bash(cargo run *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(pwd)",
      "Bash(tree *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(env *)",
      "Bash(printenv *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(mkdir *)",
      "Bash(clang-format *)",
      "Bash(clang-tidy *)",
      "Bash(cmake -S * -B *)",
      "Bash(cmake --build *)",
      "Bash(cmake --preset *)",
      "Bash(cmake -E *)",
      "Bash(ctest *)",
      "Bash(cpack *)",
      "Bash(ninja *)",
      "Bash(make *)"
    ],
    "deny": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git clean *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(uvx *)",
      "Bash(cargo add *)",
      "Bash(cargo remove *)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "awaySummaryEnabled": false,
  "autoUpdatesChannel": "latest",
  "theme": "dark-ansi"
}
